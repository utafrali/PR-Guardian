{
  "name": "pr-guardian",
  "version": "0.1.0",
  "description": "AI-powered GitHub App that automatically reviews every pull request",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "build:action": "ncc build action/index.ts -o action/dist",
    "dev": "ts-node src/index.ts",
    "start": "probot run ./dist/index.js",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "github-app",
    "probot",
    "code-review",
    "ai",
    "pull-request"
  ],
  "author": "Ugur Tafrali",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/utafrali/PR-Guardian.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "minimatch": "^10.0.1",
    "pino": "^9.6.0",
    "probot": "^13.4.3",
    "yaml": "^2.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^8.57.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
